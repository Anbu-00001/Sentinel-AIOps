# Sentinel-AIOps Advanced .gitignore

# ── Python Standard ───────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ── ML Artifacts & Data ───────────────────────────────────────────────────────
# Ignore raw Kaggle datasets to keep repo lightweight
data/raw/*.csv
data/raw/*.zip

# Ignore large generated feature matrices
data/*.npz
data/labels.npy
data/data_summary.json

# Ignore SQLite databases
data/*.db

# Ignore scikit-learn/LightGBM joblib artifacts (~100MB+)
models/*.joblib

# ── Runtime ML outputs (generated, not source) ──────────────────────────────
models/drift_report.json
models/anomaly_scores.npy
models/pr_curve.png
models/confusion_matrix.png
models/feature_importance.png
models/*.sig
models/v2_report.json
models/metrics.json

# Keep these tracked (they are source/config, not runtime outputs):
# models/feature_meta.json  ← this IS source, keep tracked
# models/registry.json      ← clean-slate committed, populated at train time

# Ignore human log subsets
data/feedback/*.json

# ── IDE & OS ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
.DS_Store
*.swp
*.db-wal
*.bak
