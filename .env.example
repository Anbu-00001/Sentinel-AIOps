# Sentinel-AIOps Environment Configuration
# Copy this file to .env and fill in real values. Never commit .env.

# REQUIRED: HMAC-SHA256 secret for model artifact signing.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
MODEL_SIGNATURE_SECRET=

# REQUIRED for production webhook validation
GITHUB_WEBHOOK_SECRET=

# REQUIRED for production API access.
# Protects /api/dashboard, /api/drift, /api/psi,
# /api/registry, /api/history endpoints.
# Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Pass in requests as: curl -H "X-API-Key: <key>" <url>
# If unset, all endpoints are open (development mode only).
SENTINEL_API_KEY=

# Optional: override SQLite path (default: data/sentinel.db)
# SENTINEL_DB_PATH=/app/data/sentinel.db

# Optional: PSI drift thresholds
# PSI_SEVERE_THRESHOLD=0.20
# PSI_MODERATE_THRESHOLD=0.10

# Optional: Retrain trigger threshold
# RETRAIN_THRESHOLD=100
